    {
      "type": "row",
      "title": "Latest snapshot",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Last reading per channel",
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUX}"},
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 37},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "left"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "value_c"},
           "properties": [{"id": "unit", "value": "celsius"}]},
          {"matcher": {"id": "byName", "options": "value_k"},
           "properties": [{"id": "unit", "value": "kelvin"}]}
        ]
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUX}"},
          "query": "from(bucket: \"xsphere\")\n  |> range(start: -10m)\n  |> filter(fn: (r) => r._measurement == \"temperature\" and r.source == \"omega\" and (r._field == \"value_c\" or r._field == \"value_k\"))\n  |> last()\n  |> keep(columns: [\"sensor_type\", \"channel\", \"_field\", \"_value\"])\n  |> pivot(rowKey: [\"sensor_type\", \"channel\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> sort(columns: [\"sensor_type\", \"channel\"])"
        }
      ]
    }
  ]
