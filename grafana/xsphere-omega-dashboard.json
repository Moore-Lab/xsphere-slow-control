      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["last", "min", "max"]},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUX}"},
          "query": "from(bucket: \"xsphere\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"temperature\" and r.source == \"omega\" and r.sensor_type == \"tc\" and r.channel == \"1\" and r._field == \"value_c\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\"])"
        }
      ]
    },
