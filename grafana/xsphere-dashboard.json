        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUX}"
          },
          "query": "from(bucket: \"xsphere\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"service_heartbeat\" or r[\"_measurement\"] == \"temperature\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"value_k\")\r\n  |> filter(fn: (r) => r[\"channel\"] == \"1\" or r[\"channel\"] == \"3\" or r[\"channel\"] == \"2\" or r[\"channel\"] == \"4\" or r[\"channel\"] == \"5\" or r[\"channel\"] == \"6\")\r\n  |> filter(fn: (r) => r[\"sensor_type\"] == \"rtd\")\r\n  |> filter(fn: (r) => r[\"source\"] == \"labjack_cal\" or r[\"source\"] == \"plc\")\r\n  |> filter(fn: (r) => r[\"system\"] == \"xsphere\")\r\n  |> filter(fn: (r) => r[\"topic\"] == \"xsphere/sensors/temperature/labjack_cal/rtd/1\" or r[\"topic\"] == \"xsphere/sensors/temperature/labjack_cal/rtd/2\" or r[\"topic\"] == \"xsphere/sensors/temperature/labjack_cal/rtd/3\" or r[\"topic\"] == \"xsphere/sensors/temperature/plc/rtd/4\" or r[\"topic\"] == \"xsphere/sensors/temperature/plc/rtd/5\" or r[\"topic\"] == \"xsphere/sensors/temperature/plc/rtd/6\")\r\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\r\n  |> map(fn: (r) => ({\r\n      _time: r._time,\r\n      _value: r._value,\r\n      _field: if r.channel == \"1\" then \"LJ1 - Nozzle (cal)\"\r\n        else if r.channel == \"2\" then \"LJ2 - Top Cube (cal)\"\r\n        else if r.channel == \"3\" then \"LJ3 - Bottom Cube (cal)\"\r\n        else if r.channel == \"4\" then \"PLC1 - Tree\"\r\n        else if r.channel == \"5\" then \"PLC2 - Top Clamp\"\r\n        else if r.channel == \"6\" then \"PLC3 - Bottom Clamp\"\r\n        else r._field\r\n    }))\r\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ],
      "title": "RTD Temp",
      "transparent": true,
      "type": "timeseries"
    },
