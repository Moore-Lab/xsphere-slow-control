    "z": "xsphere-tab",
    "name": "Format level",
    "func": "var vessel = msg.topic.split('/').pop();\nvar p = msg.payload;\nvar val = p.raw_pf !== undefined ? parseFloat(p.raw_pf).toFixed(3) + ' pF' : '?';\nif (p.valid === false) val = 'FAULT';\nmsg.payload = vessel.toUpperCase() + ': ' + val;\nreturn msg;",
