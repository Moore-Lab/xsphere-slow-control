    "name": "Format vacuum",
    "func": "var name = msg.topic.split('/').pop();\nvar mbar = msg.payload.value_mbar;\nvar disp;\nif (mbar !== undefined) {\n    var m = parseFloat(mbar);\n    if (m < 0.001) disp = m.toExponential(2) + ' mbar';\n    else disp = m.toPrecision(4) + ' mbar';\n} else {\n    disp = '?';\n}\nmsg.payload = name + ': ' + disp;\nreturn msg;",
    "outputs": 1,
    "x": 310,
    "y": 1120,
    "wires": [["ui-text-vacuum"]]
  },

