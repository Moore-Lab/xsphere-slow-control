[
  {
    "id": "xsphere-tab",
    "type": "tab",
    "label": "xsphere Slow Control",
    "disabled": false,
    "info": "xsphere cryostat slow control dashboard.\n\nImport into Node-RED running on xbox-pi (192.168.8.116:1880).\n\nRequired Node-RED packages:\n  npm install node-red-dashboard\n\nVerify MQTT broker node points to localhost:1883 (or 192.168.8.116:1883)."
  },

  {
    "id": "mqtt-broker",
    "type": "mqtt-broker",
    "name": "xbox-pi Mosquitto",
    "broker": "localhost",
    "port": "1883",
    "clientid": "nodered-xsphere-dashboard",
    "usetls": false,
    "compatmode": false,
    "protocolVersion": "5",
    "keepalive": "60",
    "cleansession": true,
    "autoConnect": true
  },

