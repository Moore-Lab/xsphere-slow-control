  {
    "id": "fn-send-base",
    "type": "function",
    "z": "xsphere-tab",
    "name": "Publish base_k",
    "func": "msg.topic = 'xsphere/commands/gradient/base';\nmsg.payload = JSON.stringify({value_k: parseFloat(msg.payload)});\nreturn msg;",
