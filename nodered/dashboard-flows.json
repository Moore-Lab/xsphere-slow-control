  {
    "id": "mqtt-in-temp-plc",
    "type": "mqtt in",
    "z": "xsphere-tab",
    "name": "PLC Temperatures",
    "topic": "xsphere/sensors/temperature/plc/#",
    "qos": "0",
    "datatype": "json",
    "broker": "mqtt-broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 100,
    "y": 80,
    "wires": [["fn-plc-temp-route"]]
  },

  {
    "id": "fn-plc-temp-route",
    "type": "function",
    "z": "xsphere-tab",
    "name": "Route PLC temps",
    "func": "// Extract channel from topic: xsphere/sensors/temperature/plc/{channel}\nvar parts = msg.topic.split('/');\nvar ch = parts[parts.length - 1];\nvar val = msg.payload.value_k;\nif (val !== undefined && val !== null) {\n    msg.payload = parseFloat(val).toFixed(3) + ' K';\n    msg.topic = ch;\n}\nreturn msg;",
    "outputs": 1,
    "x": 300,
    "y": 80,
    "wires": [["ui-text-plc-temp"]]
  },

  {
    "id": "ui-text-plc-temp",
    "type": "ui_text",
    "z": "xsphere-tab",
    "group": "grp-plc-temps",
    "order": 1,
    "width": 4,
    "height": 1,
    "name": "PLC Temp",
    "label": "{{msg.topic}}",
    "format": "{{msg.payload}}",
    "layout": "row-spread",
    "className": "",
    "x": 500,
    "y": 80,
    "wires": []
  },

  {
    "id": "mqtt-in-temp-omega",
    "type": "mqtt in",
    "z": "xsphere-tab",
    "name": "Omega Temperatures",
    "topic": "xsphere/sensors/temperature/omega/#",
    "qos": "0",
    "datatype": "json",
    "broker": "mqtt-broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 100,
    "y": 160,
    "wires": [["fn-omega-temp-route"]]
  },

  {
    "id": "fn-omega-temp-route",
    "type": "function",
    "z": "xsphere-tab",
    "name": "Route Omega temps",
    "func": "var label = msg.payload.label || msg.topic.split('/').pop();\nvar fault = msg.payload.fault;\nif (fault) {\n    msg.payload = label + ': FAULT';\n} else {\n    var k = parseFloat(msg.payload.value_k);\n    var c = parseFloat(msg.payload.value_c);\n    msg.payload = label + ': ' + k.toFixed(2) + ' K (' + c.toFixed(2) + ' °C)';\n}\nmsg.topic = label;\nreturn msg;",
    "outputs": 1,
    "x": 310,
    "y": 160,
    "wires": [["ui-text-omega-temp"]]
  },

  {
    "id": "ui-text-omega-temp",
    "type": "ui_text",
    "z": "xsphere-tab",
    "group": "grp-omega-temps",
    "order": 1,
    "width": 6,
    "height": 1,
    "name": "Omega Temp",
    "label": "",
    "format": "{{msg.payload}}",
    "layout": "row-spread",
    "className": "",
    "x": 510,
    "y": 160,
    "wires": []
  },

  {
    "id": "mqtt-in-pid-status",
    "type": "mqtt in",
    "z": "xsphere-tab",
    "name": "PID Status",
    "topic": "xsphere/status/pid/#",
    "qos": "0",
    "datatype": "json",
    "broker": "mqtt-broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 100,
    "y": 260,
    "wires": [["fn-pid-status"]]
  },

  {
    "id": "fn-pid-status",
    "type": "function",
    "z": "xsphere-tab",
    "name": "Format PID status",
    "func": "var zone = msg.topic.split('/').pop();\nvar p = msg.payload;\nvar out = p.output_pct !== undefined ? parseFloat(p.output_pct).toFixed(1) + '%' : '?';\nvar sp  = p.setpoint_k  !== undefined ? parseFloat(p.setpoint_k).toFixed(1)  + ' K' : '?';\nvar pv  = p.pv_k        !== undefined ? parseFloat(p.pv_k).toFixed(2)        + ' K' : '?';\nmsg.payload = zone.toUpperCase() + ' | SP: ' + sp + ' | PV: ' + pv + ' | OUT: ' + out;\nmsg.topic = zone;\nreturn msg;",
    "outputs": 1,
    "x": 310,
    "y": 260,
    "wires": [["ui-text-pid-status"]]
  },

  {
    "id": "ui-text-pid-status",
    "type": "ui_text",
    "z": "xsphere-tab",
    "group": "grp-pid-status",
    "order": 1,
    "width": 12,
    "height": 1,
    "name": "PID Status",
    "label": "",
    "format": "{{msg.payload}}",
    "layout": "row-spread",
    "className": "",
    "x": 510,
    "y": 260,
    "wires": []
  },

  {
    "id": "mqtt-in-gradient-status",
    "type": "mqtt in",
    "z": "xsphere-tab",
    "name": "Gradient Status",
    "topic": "xsphere/status/gradient",
    "qos": "0",
    "datatype": "json",
    "broker": "mqtt-broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 100,
    "y": 340,
    "wires": [["fn-gradient-status"]]
  },

  {
    "id": "fn-gradient-status",
    "type": "function",
    "z": "xsphere-tab",
    "name": "Gradient status display",
    "func": "var p = msg.payload;\nvar mode = p.mode || '?';\nvar base = p.base_k !== undefined ? parseFloat(p.base_k).toFixed(1) + ' K' : '?';\nvar dv   = p.delta_v_k !== undefined ? parseFloat(p.delta_v_k).toFixed(1) + ' K' : '?';\nvar dl   = p.delta_l_k !== undefined ? parseFloat(p.delta_l_k).toFixed(1) + ' K' : '?';\nmsg.payload = 'Mode: ' + mode + ' | Base: ' + base + ' | ΔV: ' + dv + ' | ΔL: ' + dl;\nreturn msg;",
    "outputs": 1,
    "x": 310,
    "y": 340,
    "wires": [["ui-text-gradient-status"]]
  },

  {
    "id": "ui-text-gradient-status",
    "type": "ui_text",
    "z": "xsphere-tab",
    "group": "grp-gradient",
