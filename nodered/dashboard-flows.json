  {
    "id": "fn-scanner-status",
    "type": "function",
    "z": "xsphere-tab",
    "name": "Format scanner status",
    "func": "var p = msg.payload;\nvar state = p.state || 'idle';\nvar step  = (p.step || 0) + 1;\nvar total = p.total_steps || 0;\nvar sp    = p.setpoint_k !== undefined ? parseFloat(p.setpoint_k).toFixed(1) + ' K' : '?';\nvar elapsed = p.elapsed_s !== undefined ? parseFloat(p.elapsed_s).toFixed(0) + ' s' : '?';\nif (state === 'idle') {\n    msg.payload = 'Idle';\n} else {\n    msg.payload = state.toUpperCase() + ' | Step ' + step + '/' + total + ' | SP: ' + sp + ' | Elapsed: ' + elapsed;\n}\nreturn msg;",
    "outputs": 1,
    "x": 340,
    "y": 1400,
    "wires": [["ui-text-scanner-status"]]
