  {
    "id": "fn-env-display",
    "type": "function",
    "z": "xsphere-tab",
    "name": "Format environment",
    "func": "var name = msg.topic.split('/').pop();\nvar p = msg.payload;\nvar parts = [];\nif (p.temperature_c !== undefined) parts.push(parseFloat(p.temperature_c).toFixed(1) + '°C');\nif (p.humidity_pct  !== undefined) parts.push(parseFloat(p.humidity_pct).toFixed(0) + '%RH');\nif (p.pressure_hpa  !== undefined) parts.push(parseFloat(p.pressure_hpa).toFixed(1) + ' hPa');\nmsg.payload = name + ': ' + (parts.length ? parts.join(' | ') : '?');\nreturn msg;",
    "outputs": 1,
    "x": 320,
    "y": 1200,
    "wires": [["ui-text-environment"]]
