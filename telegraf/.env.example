# Telegraf environment variables
# Copy to .env and fill in values before deploying.
# In IOTstack, these are injected via docker-compose.override.yml or the
# stack's .env file in ~/IOTstack/.

# InfluxDB 2.x connection
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=xsphere
INFLUX_BUCKET=xsphere

# MQTT broker (use Docker service name when running in IOTstack)
MQTT_HOST=mosquitto
MQTT_PORT=1883
